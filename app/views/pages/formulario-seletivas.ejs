<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Formulário de Inscrição - Cordas Soltas</title>
    <link rel="stylesheet" href="css/formulario.css">
    <link href="https://fonts.googleapis.com/css2?family=Odibee+Sans&family=Roboto:wght@400;700&display=swap" rel="stylesheet">
</head>
<body class="formulario-page">
    <!-- ELEMENTO NECESSARIO PARA FUNCIONAMENTO DO PLUGIN, NAO APAGAR!-->
    <section vw class="enabled">
        <div vw-access-button class="active"></div>
        <div vw-plugin-wrapper>
            <div class="vw-plugin-top-wrapper"></div>
        </div>
    </section>
    <script src="https://vlibras.gov.br/app/vlibras-plugin.js"></script>
    <script>new window.VLibras.Widget('https://vlibras.gov.br/app');</script>
    <!-- ELEMENTO NECESSARIO PARA FUNCIONAMENTO DO PLUGIN, NAO APAGAR!-->

    <main class="formulario-wrapper">

        <!-- Botão Voltar -->
        <nav>
            <a href="/seletivas" class="f-voltar">
                <span>&#8592;</span> Voltar
            </a>
        </nav>

        <!-- Título -->
        <header>
            <h1 class="f-titulo">Formulário de Inscrição</h1>
        </header>

        <!-- Mensagem de erro do servidor -->
        <% if (typeof erro !== 'undefined' && erro) { %>
            <section class="f-aviso erro">
                <span class="f-aviso-icone">⚠️</span>
                <span><%= erro %></span>
            </section>
        <% } %>

        <!-- Mensagem de sucesso do servidor -->
        <% if (typeof sucesso !== 'undefined' && sucesso) { %>
            <section class="f-aviso sucesso">
                <span class="f-aviso-icone">✅</span>
                <span><%= sucesso %></span>
            </section>
        <% } %>

        <form id="formulario-inscricao" method="POST" action="/formulario-seletivas"
              enctype="multipart/form-data" novalidate>

            <!-- ══════════════════════════════════════════════════════
                 SEÇÃO 1 – Dados do Responsável
            ═══════════════════════════════════════════════════════ -->
            <section class="f-secao">
                <h2 class="f-secao-titulo">Dados do Responsável</h2>

                <fieldset class="f-grupo">
                    <label for="nome_completo" class="f-label">Nome Completo</label>
                    <input type="text" id="nome_completo" name="nome_completo"
                           class="f-input" placeholder="Seu nome" required>
                    <span class="f-campo-erro-msg" id="err-nome">Campo obrigatório.</span>
                </fieldset>

                <fieldset class="f-grupo">
                    <label for="email_contato" class="f-label">E-mail de Contato</label>
                    <input type="email" id="email_contato" name="email_contato"
                           class="f-input" placeholder="exemplo@gmail.com" required>
                    <span class="f-campo-erro-msg" id="err-email">E-mail inválido.</span>
                </fieldset>

                <fieldset class="f-grupo">
                    <label for="cpf" class="f-label">CPF</label>
                    <input type="text" id="cpf" name="cpf"
                           class="f-input" placeholder="000.000.000-00"
                           maxlength="14" required>
                    <span class="f-campo-erro-msg" id="err-cpf">CPF inválido.</span>
                </fieldset>

                <fieldset class="f-grupo">
                    <label for="rg" class="f-label">RG</label>
                    <input type="text" id="rg" name="rg"
                           class="f-input" placeholder="00.000.000-0"
                           maxlength="13" required>
                    <span class="f-campo-erro-msg" id="err-rg">Campo obrigatório.</span>
                </fieldset>
            </section>

            <!-- ══════════════════════════════════════════════════════
                 SEÇÃO 2 – Perfil da Banda/Artista
            ═══════════════════════════════════════════════════════ -->
            <section class="f-secao">
                <h2 class="f-secao-titulo">Perfil da Banda/Artista</h2>

                <fieldset class="f-grupo">
                    <label for="nome_banda" class="f-label">Nome da(o) banda/artista</label>
                    <input type="text" id="nome_banda" name="nome_banda"
                           class="f-input" placeholder="Seu nome" required>
                    <span class="f-campo-erro-msg" id="err-banda">Campo obrigatório.</span>
                </fieldset>

                <fieldset class="f-grupo">
                    <label for="estilo_musical" class="f-label">Qual estilo musical?</label>
                    <div class="f-select-wrapper">
                        <select id="estilo_musical" name="estilo_musical"
                                class="f-select" required>
                            <option value="" disabled selected>selecione um estilo...</option>
                            <option value="Rock">Rock</option>
                            <option value="Samba">Samba</option>
                            <option value="Pagode">Pagode</option>
                            <option value="Jazz">Jazz</option>
                            <option value="Eletrônica">Eletrônica</option>
                            <option value="Forró">Forró</option>
                            <option value="Sertanejo">Sertanejo</option>
                            <option value="MPB">MPB</option>
                            <option value="Reggae">Reggae</option>
                            <option value="Hip-Hop/Rap">Hip-Hop / Rap</option>
                            <option value="Metal">Metal</option>
                            <option value="Pop">Pop</option>
                            <option value="Outro">Outro</option>
                        </select>
                    </div>
                    <span class="f-campo-erro-msg" id="err-estilo">Selecione um estilo.</span>
                </fieldset>

                <fieldset class="f-grupo">
                    <legend class="f-label">Quantos Integrantes?</legend>
                    <div class="f-radio-grupo">

                        <label class="f-radio-item">
                            <input type="radio" name="num_integrantes" value="solo" required>
                            <span class="f-radio-circulo"></span>
                            <span class="f-radio-txt">Artista Solo</span>
                        </label>

                        <label class="f-radio-item">
                            <input type="radio" name="num_integrantes" value="2a4">
                            <span class="f-radio-circulo"></span>
                            <span class="f-radio-txt">2 a 4 Integrantes</span>
                        </label>

                        <label class="f-radio-item">
                            <input type="radio" name="num_integrantes" value="mais4">
                            <span class="f-radio-circulo"></span>
                            <span class="f-radio-txt">Mais de 4 Integrantes</span>
                        </label>

                    </div>
                    <span class="f-campo-erro-msg" id="err-integrantes">Selecione uma opção.</span>
                </fieldset>

                <fieldset class="f-grupo">
                    <label for="publico_alvo" class="f-label">Qual o Público-Alvo?</label>
                    <textarea id="publico_alvo" name="publico_alvo"
                              class="f-textarea"
                              placeholder="Descreva o público que a banda atrai"></textarea>
                </fieldset>

                <fieldset class="f-grupo">
                    <label for="redes_sociais" class="f-label">Redes Sociais</label>
                    <input type="text" id="redes_sociais" name="redes_sociais"
                           class="f-input"
                           placeholder="link do perfil da banda">
                </fieldset>

                <!-- ── Upload: Clipe/Vídeo ──────────────────────────────── -->
                <fieldset class="f-grupo">
                    <label class="f-label">Clipe ou Lyric video da banda</label>
                    <div class="f-upload-area" id="upload-clipe-area">
                        <input type="file" name="clipe_video"
                               accept="video/*,.mp4,.mov,.avi"
                               id="upload-clipe">
                        <div class="f-upload-placeholder" id="upload-clipe-placeholder">
                            <div class="f-upload-icone">&#8681;</div>
                            <span class="f-upload-txt">Adicionar arquivo de vídeo</span>
                        </div>
                        <div class="f-video-preview-wrap" id="upload-clipe-preview" hidden></div>
                        <div class="f-upload-acoes" id="upload-clipe-acoes" hidden>
                            <button type="button" class="f-upload-btn-acao" id="btn-trocar-video">Trocar v&iacute;deo</button>
                            <button type="button" class="f-upload-btn-acao remover" id="btn-remover-video">Remover</button>
                        </div>
                    </div>
                </fieldset>

                <!-- ── Upload: Fotos da banda ───────────────────────────── -->
                <fieldset class="f-grupo">
                    <label class="f-label">
                        Envie até 5 fotos da banda
                        <span class="f-label-obs">
                            Use alta qualidade para os arquivos em alta resolução.
                            Recomendamos fotos do show ou ensaio, que serão utilizadas na divulgação caso
                            a banda seja selecionada.
                        </span>
                    </label>
                    <div class="f-upload-area" id="upload-fotos-area">
                        <input type="file" name="fotos_banda"
                               accept="image/*"
                               multiple
                               id="upload-fotos">
                        <div class="f-upload-placeholder" id="upload-fotos-placeholder">
                            <div class="f-upload-icone">&#8681;</div>
                            <span class="f-upload-txt">Adicionar fotos (até 5)</span>
                        </div>
                        <div class="f-upload-previews" id="upload-fotos-preview" hidden></div>
                        <div class="f-upload-acoes" id="upload-fotos-acoes" hidden>
                            <button type="button" class="f-upload-btn-acao" id="btn-add-fotos">Adicionar mais</button>
                            <button type="button" class="f-upload-btn-acao remover" id="btn-limpar-fotos">Remover todas</button>
                        </div>
                    </div>
                </fieldset>

            </section>

            <!-- ── Botão Enviar ──────────────────────────────────── -->
            <footer>
                <button type="submit" class="f-btn-enviar" id="btn-enviar">
                    enviar
                </button>
            </footer>

        </form>
    </main>

    <script>
    // ══════════════════════════════════════════════════════════════════
    //  UPLOAD COM PREVIEW
    // ══════════════════════════════════════════════════════════════════

    const fmt = bytes => {
        if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(0) + ' KB';
        return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
    };

    // ── VÍDEO ─────────────────────────────────────────────────────────
    (function initVideoUpload() {
        return;
        const area        = document.getElementById('upload-clipe-area');
        const inputMain   = document.getElementById('upload-clipe');
        const inputHidden = document.getElementById('upload-clipe-hidden');

        function renderVideoPreview(file) {
            area.classList.add('tem-arquivo');
            // Remove input principal da área (desativa clique na área)
            inputMain.style.pointerEvents = 'none';
            inputMain.style.width = '0';
            inputMain.style.height = '0';

            // Cria URL de objeto para preview
            const url = URL.createObjectURL(file);

            area.innerHTML = `
                <div class="f-video-preview-wrap">
                    <video src="${url}" controls preload="metadata"></video>
                    <div class="f-video-meta">
                        <span class="f-video-meta-icone">🎬</span>
                        <div class="f-video-meta-info">
                            <div class="f-video-meta-nome">${file.name}</div>
                            <div class="f-video-meta-tamanho">${fmt(file.size)}</div>
                        </div>
                    </div>
                </div>
                <div class="f-upload-acoes">
                    <button type="button" class="f-upload-btn-acao" id="btn-trocar-video">
                        ↺ Trocar vídeo
                    </button>
                    <button type="button" class="f-upload-btn-acao remover" id="btn-remover-video">
                        ✕ Remover
                    </button>
                </div>
            `;

            document.getElementById('btn-trocar-video').addEventListener('click', () => {
                inputHidden.click();
            });
            document.getElementById('btn-remover-video').addEventListener('click', () => {
                URL.revokeObjectURL(url);
                resetVideoArea();
            });
        }

        function resetVideoArea() {
            area.classList.remove('tem-arquivo');
            area.innerHTML = `
                <input type="file" name="clipe_video" accept="video/*,.mp4,.mov,.avi" id="upload-clipe">
                <div class="f-upload-placeholder">
                    <div class="f-upload-icone">&#8681;</div>
                    <span class="f-upload-txt">Adicionar arquivo de vídeo</span>
                </div>
            `;
            // Re-vincula evento ao novo input
            document.getElementById('upload-clipe').addEventListener('change', onVideoChange);
        }

        function onVideoChange(e) {
            const file = e.target.files[0];
            if (!file) return;
            renderVideoPreview(file);
        }

        inputMain.addEventListener('change', onVideoChange);

        // Input hidden (troca)
        inputHidden.addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (!file) return;
            renderVideoPreview(file);
        });
    })();


    // ── FOTOS ─────────────────────────────────────────────────────────
    (function initFotosUpload() {
        return;
        const area        = document.getElementById('upload-fotos-area');
        const inputMain   = document.getElementById('upload-fotos');
        const inputHidden = document.getElementById('upload-fotos-hidden');
        const MAX_FOTOS   = 5;
        let fotosAtivas   = []; // Array de { file, url }

        function renderFotos() {
            if (fotosAtivas.length === 0) {
                resetFotosArea();
                return;
            }

            area.classList.add('tem-arquivo');
            inputMain.style.pointerEvents = 'none';
            inputMain.style.width = '0';
            inputMain.style.height = '0';

            const limitado = fotosAtivas.slice(0, MAX_FOTOS);
            const excedeu  = fotosAtivas.length > MAX_FOTOS;

            let gridHtml = limitado.map((item, idx) => `
                <div class="f-preview-item" data-idx="${idx}">
                    <img class="f-preview-img" src="${item.url}" alt="${item.file.name}">
                    <div class="f-preview-overlay">
                        <div class="f-preview-nome">${item.file.name}</div>
                        <div class="f-preview-tamanho">${fmt(item.file.size)}</div>
                    </div>
                    <button type="button" class="f-preview-remover" data-idx="${idx}" title="Remover">✕</button>
                </div>
            `).join('');

            if (excedeu) {
                gridHtml += `<div class="f-upload-aviso-max">⚠ Máximo de ${MAX_FOTOS} fotos. As primeiras ${MAX_FOTOS} serão usadas.</div>`;
            }

            area.innerHTML = `
                <div class="f-upload-previews">${gridHtml}</div>
                <div class="f-upload-acoes">
                    ${fotosAtivas.length < MAX_FOTOS
                        ? `<button type="button" class="f-upload-btn-acao" id="btn-add-fotos">+ Adicionar mais</button>`
                        : ''}
                    <button type="button" class="f-upload-btn-acao remover" id="btn-limpar-fotos">✕ Remover todas</button>
                </div>
            `;

            // Botão remover individual
            area.querySelectorAll('.f-preview-remover').forEach(btn => {
                btn.addEventListener('click', function() {
                    const idx = parseInt(this.dataset.idx);
                    URL.revokeObjectURL(fotosAtivas[idx].url);
                    fotosAtivas.splice(idx, 1);
                    renderFotos();
                });
            });

            // Adicionar mais
            const btnAdd = document.getElementById('btn-add-fotos');
            if (btnAdd) {
                btnAdd.addEventListener('click', () => inputHidden.click());
            }

            // Remover todas
            document.getElementById('btn-limpar-fotos').addEventListener('click', () => {
                fotosAtivas.forEach(f => URL.revokeObjectURL(f.url));
                fotosAtivas = [];
                resetFotosArea();
            });
        }

        function resetFotosArea() {
            area.classList.remove('tem-arquivo');
            area.innerHTML = `
                <input type="file" name="fotos_banda" accept="image/*" multiple id="upload-fotos">
                <div class="f-upload-placeholder">
                    <div class="f-upload-icone">&#8681;</div>
                    <span class="f-upload-txt">Adicionar fotos (até ${MAX_FOTOS})</span>
                </div>
            `;
            document.getElementById('upload-fotos').addEventListener('change', onFotosChange);
        }

        function onFotosChange(e) {
            const novos = Array.from(e.target.files);
            if (!novos.length) return;
            novos.forEach(file => {
                if (fotosAtivas.length < MAX_FOTOS * 2) { // permite acumular mas avisa
                    fotosAtivas.push({ file, url: URL.createObjectURL(file) });
                }
            });
            renderFotos();
        }

        inputMain.addEventListener('change', onFotosChange);

        // Input hidden (adicionar mais)
        inputHidden.addEventListener('change', function(e) {
            const novos = Array.from(e.target.files);
            if (!novos.length) return;
            novos.forEach(file => {
                fotosAtivas.push({ file, url: URL.createObjectURL(file) });
            });
            renderFotos();
        });
    })();


    // ══════════════════════════════════════════════════════════════════
    (function initVideoUploadCorrigido() {
        const area = document.getElementById('upload-clipe-area');
        const input = document.getElementById('upload-clipe');
        const placeholder = document.getElementById('upload-clipe-placeholder');
        const preview = document.getElementById('upload-clipe-preview');
        const actions = document.getElementById('upload-clipe-acoes');
        const btnTrocar = document.getElementById('btn-trocar-video');
        const btnRemover = document.getElementById('btn-remover-video');
        let videoUrl = null;

        if (!area || !input || !placeholder || !preview || !actions) return;

        function limparVideoUrl() {
            if (videoUrl) {
                URL.revokeObjectURL(videoUrl);
                videoUrl = null;
            }
        }

        function resetVideo() {
            limparVideoUrl();
            input.value = '';
            preview.innerHTML = '';
            preview.hidden = true;
            actions.hidden = true;
            placeholder.hidden = false;
            area.classList.remove('tem-arquivo');
        }

        function renderVideo(file) {
            limparVideoUrl();
            videoUrl = URL.createObjectURL(file);
            preview.innerHTML = `
                <video src="${videoUrl}" controls preload="metadata"></video>
                <div class="f-video-meta">
                    <span class="f-video-meta-icone">Video</span>
                    <div class="f-video-meta-info">
                        <div class="f-video-meta-nome">${file.name}</div>
                        <div class="f-video-meta-tamanho">${fmt(file.size)}</div>
                    </div>
                </div>
            `;
            placeholder.hidden = true;
            preview.hidden = false;
            actions.hidden = false;
            area.classList.add('tem-arquivo');
        }

        input.addEventListener('change', (event) => {
            const file = event.target.files[0];
            if (!file) {
                resetVideo();
                return;
            }
            renderVideo(file);
        });

        btnTrocar.addEventListener('click', () => input.click());
        btnRemover.addEventListener('click', resetVideo);
    })();

    (function initFotosUploadCorrigido() {
        const area = document.getElementById('upload-fotos-area');
        const input = document.getElementById('upload-fotos');
        const placeholder = document.getElementById('upload-fotos-placeholder');
        const preview = document.getElementById('upload-fotos-preview');
        const actions = document.getElementById('upload-fotos-acoes');
        const btnAdd = document.getElementById('btn-add-fotos');
        const btnLimpar = document.getElementById('btn-limpar-fotos');
        const MAX_FOTOS = 5;
        let fotosAtivas = [];

        if (!area || !input || !placeholder || !preview || !actions) return;

        function sincronizarInput() {
            const transfer = new DataTransfer();
            fotosAtivas.slice(0, MAX_FOTOS).forEach((item) => transfer.items.add(item.file));
            input.files = transfer.files;
        }

        function limparFotoUrl(item) {
            if (item && item.url) {
                URL.revokeObjectURL(item.url);
            }
        }

        function resetFotos() {
            fotosAtivas.forEach(limparFotoUrl);
            fotosAtivas = [];
            input.value = '';
            preview.innerHTML = '';
            preview.hidden = true;
            actions.hidden = true;
            placeholder.hidden = false;
            area.classList.remove('tem-arquivo');
            sincronizarInput();
        }

        function renderFotos() {
            sincronizarInput();

            if (fotosAtivas.length === 0) {
                resetFotos();
                return;
            }

            const fotosHtml = fotosAtivas.map((item, idx) => `
                <div class="f-preview-item" data-idx="${idx}">
                    <img class="f-preview-img" src="${item.url}" alt="${item.file.name}">
                    <div class="f-preview-overlay">
                        <div class="f-preview-nome">${item.file.name}</div>
                        <div class="f-preview-tamanho">${fmt(item.file.size)}</div>
                    </div>
                    <button type="button" class="f-preview-remover" data-idx="${idx}" title="Remover">x</button>
                </div>
            `).join('');

            preview.innerHTML = fotosHtml;
            preview.hidden = false;
            actions.hidden = false;
            placeholder.hidden = true;
            area.classList.add('tem-arquivo');
            btnAdd.hidden = fotosAtivas.length >= MAX_FOTOS;

            preview.querySelectorAll('.f-preview-remover').forEach((button) => {
                button.addEventListener('click', () => {
                    const idx = Number.parseInt(button.dataset.idx, 10);
                    limparFotoUrl(fotosAtivas[idx]);
                    fotosAtivas.splice(idx, 1);
                    renderFotos();
                });
            });
        }

        input.addEventListener('change', (event) => {
            const novosArquivos = Array.from(event.target.files || []);
            const vagas = MAX_FOTOS - fotosAtivas.length;
            const selecionados = novosArquivos.slice(0, vagas);

            selecionados.forEach((file) => {
                fotosAtivas.push({
                    file,
                    url: URL.createObjectURL(file)
                });
            });

            renderFotos();
        });

        btnAdd.addEventListener('click', () => {
            input.value = '';
            input.click();
        });

        btnLimpar.addEventListener('click', resetFotos);
    })();

    //  MÁSCARAS
    // ══════════════════════════════════════════════════════════════════

    function mascaraCPF(input) {
        let v = input.value.replace(/\D/g, '');
        v = v.replace(/(\d{3})(\d)/, '$1.$2');
        v = v.replace(/(\d{3})(\d)/, '$1.$2');
        v = v.replace(/(\d{3})(\d{1,2})$/, '$1-$2');
        input.value = v;
    }
    function mascaraRG(input) {
        let v = input.value.replace(/\D/g, '');
        v = v.replace(/(\d{2})(\d)/, '$1.$2');
        v = v.replace(/(\d{3})(\d)/, '$1.$2');
        v = v.replace(/(\d{3})(\d{1})$/, '$1-$2');
        input.value = v;
    }

    document.getElementById('cpf').addEventListener('input', function() { mascaraCPF(this); });
    document.getElementById('rg').addEventListener('input',  function() { mascaraRG(this);  });


    // ══════════════════════════════════════════════════════════════════
    //  VALIDAÇÃO CLIENT-SIDE
    // ══════════════════════════════════════════════════════════════════

    const form = document.getElementById('formulario-inscricao');

    function mostrarErro(errId, inputEl) {
        const span = document.getElementById(errId);
        if (span) span.style.display = 'block';
        if (inputEl) inputEl.classList.add('campo-erro');
    }
    function limparErro(errId, inputEl) {
        const span = document.getElementById(errId);
        if (span) span.style.display = 'none';
        if (inputEl) inputEl.classList.remove('campo-erro');
    }

    ['nome_completo','email_contato','cpf','rg','nome_banda'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.addEventListener('input', () => {
            const errMap = { nome_completo:'err-nome', email_contato:'err-email',
                             cpf:'err-cpf', rg:'err-rg', nome_banda:'err-banda' };
            limparErro(errMap[id], el);
        });
    });

    form.addEventListener('submit', function(e) {
        let ok = true;

        const campos = [
            { id: 'nome_completo', errId: 'err-nome' },
            { id: 'email_contato', errId: 'err-email' },
            { id: 'cpf',           errId: 'err-cpf'   },
            { id: 'rg',            errId: 'err-rg'    },
            { id: 'nome_banda',    errId: 'err-banda'  },
        ];

        campos.forEach(c => limparErro(c.errId, document.getElementById(c.id)));
        limparErro('err-estilo',      document.getElementById('estilo_musical'));
        limparErro('err-integrantes', null);

        campos.forEach(c => {
            const el = document.getElementById(c.id);
            if (!el || !el.value.trim()) { mostrarErro(c.errId, el); ok = false; }
        });

        const emailEl = document.getElementById('email_contato');
        if (emailEl && emailEl.value && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailEl.value)) {
            mostrarErro('err-email', emailEl); ok = false;
        }

        const estilo = document.getElementById('estilo_musical');
        if (!estilo || !estilo.value) { mostrarErro('err-estilo', estilo); ok = false; }

        const integrante = document.querySelector('input[name="num_integrantes"]:checked');
        if (!integrante) { mostrarErro('err-integrantes', null); ok = false; }

        if (!ok) { e.preventDefault(); return; }

        // Ripple no botão
        const btn = document.getElementById('btn-enviar');
        btn.disabled = true;
        btn.textContent = 'enviando...';

        const ripple = document.createElement('span');
        ripple.className = 'f-ripple';
        const rect = btn.getBoundingClientRect();
        const size = Math.max(rect.width, rect.height);
        ripple.style.cssText = `
            width: ${size}px; height: ${size}px;
            left: ${rect.width / 2 - size / 2}px;
            top:  ${rect.height / 2 - size / 2}px;
        `;
        btn.appendChild(ripple);
        setTimeout(() => ripple.remove(), 600);
    });
    </script>
</body>
</html>
