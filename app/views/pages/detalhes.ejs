<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Detalhes do Show - <%= show.titulo %></title>
    <link rel="stylesheet" href="css/header-nav.css">
    <link rel="stylesheet" href="css/detalhes.css">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&display=swap" rel="stylesheet">
    <style>
        /* ── Avisos de validação dinâmicos ────────────────────────────────── */
        .aviso-validacao {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            padding: 12px 16px;
            border-radius: 8px;
            font-size: 0.95rem;
            font-weight: 500;
            margin-top: 14px;
            opacity: 0;
            visibility: hidden;
            transform: translateY(-8px);
            transition: all 0.3s ease;
        }
        .aviso-validacao.visivel {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }
        .aviso-validacao.erro {
            background-color: #2a0000;
            border: 1px solid #c0392b;
            color: #ff6b6b;
        }
        .aviso-validacao.aviso {
            background-color: #1a1500;
            border: 1px solid #b8860b;
            color: #ffd700;
        }
        .aviso-validacao a {
            color: #FFD700;
            font-weight: 700;
            text-decoration: underline;
        }
    </style>
</head>
<body>
    <section vw class="enabled">
        <section vw-access-button class="active"></section>
        <section vw-plugin-wrapper>
            <section class="vw-plugin-top-wrapper"></section>
        </section>
    </section>
    <%- include("../partials/header.ejs"); %>

    <main class="main-content">
        <aside class="banner-side left">
            <img src="https://i.pinimg.com/736x/ac/b3/72/acb3728c928849aa524c05f41efa1773.jpg" alt="Anúncio">
        </aside>

        <section class="details-and-back-container">
            <a href="/" class="back-link">&larr; Voltar para Eventos</a>
            
            <article class="show-details-container">
                <section class="show-image-wrapper">
                    <img src="<%= show.imagem_url %>" alt="<%= show.titulo %>" class="show-image">
                </section>

                <section class="show-info-wrapper">
                    <header class="show-info">
                        <h1><%= show.titulo %></h1>
                        <p>🎸 Gênero: <strong><%= show.estilo %></strong></p>
                        <p>📅 Data: <%= show.data_show %></p>
                        <p>📍 Local: <%= show.local %></p>
                    </header>

                    <section class="purchase-section">
                        <section class="ticket-option">
                            <section class="ticket-name">
                                <h3>Pista Inteira</h3>
                                <span class="ticket-price">
                                    <%= parseFloat(show.preco).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }) %>
                                </span>
                            </section>
                            <section class="quantity-control">
                                <button class="quantity-btn minus" data-type="full" type="button">-</button>
                                <input type="number" id="qty-full" value="0" min="0" max="10" readonly>
                                <button class="quantity-btn plus" data-type="full" type="button">+</button>
                            </section>
                        </section>

                        <section class="ticket-option">
                            <section class="ticket-name">
                                <h3>Pista Meia-Entrada</h3>
                                <span class="ticket-price">
                                    <%= parseFloat(show.preco / 2).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }) %>
                                </span>
                            </section>
                            <section class="quantity-control">
                                <button class="quantity-btn minus" data-type="half" type="button">-</button>
                                <input type="number" id="qty-half" value="0" min="0" max="10" readonly>
                                <button class="quantity-btn plus" data-type="half" type="button">+</button>
                            </section>
                        </section>

                        <section class="total-summary">
                            <h3>Total:</h3>
                            <span id="total-value" class="total-price">R$ 0,00</span>
                        </section>

                        <button id="buy-button" class="buy-button">Comprar Ingressos</button>

                        <section id="error-message" class="aviso-validacao erro" role="alert">
                            <span>⚠️ Selecione pelo menos um ingresso para continuar.</span>
                        </section>

                        <section id="aviso-login" class="aviso-validacao aviso" role="alert">
                            <span>🔒 Você precisa estar logado para comprar. <a href="/login">Fazer Login</a></span>
                        </section>
                    </section>
                </section>
            </article>
        </section>

        <aside class="banner-side right">
            <img src="https://st2.depositphotos.com/3802717/48785/v/1600/depositphotos_487853802-stock-illustration-live-rock-music-show-concert.jpg" alt="Anúncio">
        </aside>
    </main>

    <%- include("../partials/header.ejs"); %>

    <script>
        const usuarioLogado = <%- usuario ? 'true' : 'false' %>;
        const showRealDoBanco = {
            id: "<%= show.id %>",
            title: "<%= show.titulo %>",
            priceFull: parseFloat("<%= show.preco %>"),
            priceHalf: parseFloat("<%= show.preco / 2 %>")
        };
    </script>

    <script src="js/detalhes.js"></script>
    <script src="js/script.js"></script>
</body>
</html>