<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Painel de Ingressos - Cordas Soltas</title>
    <link rel="stylesheet" href="/css/admin-dashboard.css">
</head>
<body class="admin-ingressos-page">

    <hr class="top-line">

    <header class="main-header">
        <img src="/img/LOGO ALTERNATIVA CORDAS SOLTAS SITE.png" width="50px" alt="Logo Cordas Soltas" class="logo">
    </header>

    <section class="app-container">
        
        <nav class="sidebar-nav">
            <ul>
                <li onclick="window.location.href='/adm/cadastro'"><img src="/img/perfil-icon.png" width="10px"> Cadastro</li>
                <li class="active" onclick="window.location.href='/adm/ingressos'"><img src="/img/ingressos-icon.png" width="10px"> Ingressos</li>
                <li><img src="/img/luthbox-icon.png" width="10px"> Luthbox</li>
                <li onclick="window.location.href='/adm/formularios'"><img src="/img/formulario-icon.png" width="10px"> Formul&aacute;rios</li>
            </ul>
        </nav>

        <main class="content-area">
            <header class="sub-header">
                <span class="title">Gerenciamento de Ingressos</span>
                <button class="btn-add ticket-add-button" type="button" onclick="window.location.href='/adm/ingressos/adicionar'">
                    <span>+</span> Novo Ingresso
                </button>
            </header>

            <% Object.keys(showsPorEstilo).forEach(function(estilo) { %>
                <h3 class="category-title ticket-genre-title"><%= estilo %></h3>
                
                <div class="tickets-grid">
                    <% showsPorEstilo[estilo].forEach(function(show) { %>
                        <div class="ticket-card">
                            <img class="ticket-card-image" src="<%= show.imagem_url || '/img/pexels-wendywei-1190297.jpg' %>" alt="Banner" onerror="this.onerror=null;this.src='/img/pexels-wendywei-1190297.jpg';">
                            <h4 class="ticket-card-title"><%= show.titulo %></h4>
                            <p class="ticket-card-location"><%= show.local %></p>
                            <p class="ticket-card-price">R$ <%= show.preco %></p>
                            
                            <div class="ticket-card-actions">
                                <button class="btn-action ticket-edit-button" type="button" onclick="window.location.href='/adm/ingressos/editar/<%= show.id %>'"><img src="/img/confg.png" width="15px"> Editar</button>
                                
                                <button class="btn-action ticket-delete-button" type="button" onclick="abrirModalExclusao('<%= show.id %>')"><img src="/img/x-icon.png" width="15px"> Excluir</button>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% }); %>

        </main>
    </section>

    <dialog id="modal_exclusao">
        <h3>Atenção!</h3>
        <p>Tem certeza que deseja excluir este ingresso do sistema? Esta ação não poderá ser desfeita.</p>
        
        <section class="modal-botoes">
            <button id="btn_fechar_modal" class="btn-modal btn-modal-cancelar" type="button">Voltar</button>
            <button id="btn_confirmar_exclusao" class="btn-modal btn-modal-excluir" type="button">Sim, Excluir</button>
        </section>
    </dialog>

    <script>
        let idParaExcluir = null;
        const modal = document.getElementById('modal_exclusao');
        const btnFechar = document.getElementById('btn_fechar_modal');
        const btnConfirmar = document.getElementById('btn_confirmar_exclusao');

        function abrirModalExclusao(id) {
            idParaExcluir = id;
            modal.showModal(); 
        }

        function fecharModal() {
            idParaExcluir = null;
            modal.close();
        }

        btnFechar.addEventListener('click', fecharModal);

        btnConfirmar.addEventListener('click', async function() {
            if (!idParaExcluir) return;

            try {
                const resposta = await fetch(`/adm/ingressos/excluir/${idParaExcluir}`, {
                    method: 'POST',
                    headers: {
                        'Accept': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });

                const resultado = await resposta.json();

                if (resultado.sucesso) {
                    window.location.reload(); 
                } else {
                    alert("Erro: " + resultado.mensagem);
                }
            } catch (err) {
                console.error("Falha ao comunicar com o servidor:", err);
            } finally {
                fecharModal();
            }
        });
    </script>
</body>
</html>
