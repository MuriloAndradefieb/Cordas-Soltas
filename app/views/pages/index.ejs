<!DOCTYPE html>
<html lang="pt-br"> 
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cordas Soltas</title>
    <link rel="stylesheet" href="css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&display=swap" rel="stylesheet">
</head>
<body>

    <%- include("../partials/header"); %>

    <main class="main-content">

        <section class="banner-carousel" id="auto-banner-carousel">
            <a class="banner-slide active">
                <img src="https://i.pinimg.com/1200x/55/00/2a/55002af325af0ee18bb99c57d0a09ab0.jpg" alt="Banner Roda de Samba" class="banner-image">
            </a>
            <a class="banner-slide">
                <img src="https://i.pinimg.com/736x/80/5a/6e/805a6ee351e3bebdb84b3a492037cd5c.jpg" alt="Banner Rock Promoção" class="banner-image">
            </a>
            <a class="banner-slide">
                <img src="https://i.pinimg.com/736x/38/a1/15/38a115b087af38289413aaa96c8130c6.jpg" alt="Banner Jazz Festival" class="banner-image">
            </a>
        </section>

        <section class="carousels-container">

            <% if (typeof showsPorEstilo === 'undefined' || Object.keys(showsPorEstilo).length === 0) { %>
                
                <article class="carousel-wrapper" style="text-align: center; padding: 40px 20px;">
                    <header class="carousel-header">
                        <h2 style="color: #b3b3b3;">Nenhum show disponível no momento.</h2>
                    </header>
                    <p style="color: #666;">Novos eventos aparecerão aqui automaticamente assim que forem cadastrados.</p>
                </article>

            <% } else { %>

                <% for (let estilo in showsPorEstilo) { %>
                    
                    <article class="carousel-wrapper">
                        <header class="carousel-header">
                            <h2><%= estilo %></h2>
                        </header>
                        
                        <nav class="carousel-container">
                            <button class="carousel-nav prev-btn">&#10094;</button>
                            
                            <ul class="carousel-cards" id="<%= estilo.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, "").replace(/\s+/g, '-') %>-carousel">
                                
                                <% showsPorEstilo[estilo].forEach(function(show) { %>
                                    <a href="/detalhes?id=<%= show.id %>">
                                        <li class="card">
                                            <img src="<%= show.imagem_url || show.imagem || '/img/pexels-wendywei-1190297.jpg' %>" alt="<%= show.titulo %>" class="card-image" onerror="this.onerror=null;this.src='/img/pexels-wendywei-1190297.jpg';">
                                            
                                            <section class="card-info">
                                                <h3><%= show.titulo %></h3>
                                                
                                                <p class="card-date">
                                                    &#128197; <%= new Date(show.data_show || show.data).toLocaleDateString('pt-BR', { timeZone: 'UTC', day: '2-digit', month: '2-digit' }) %>
                                                </p>
                                                
                                                <p class="card-location">&#128205; <%= show.local %></p>
                                            </section>
                                        </li>
                                    </a>
                                <% }); %>

                            </ul>
                            
                            <button class="carousel-nav next-btn">&#10095;</button>
                        </nav>
                    </article>

                <% } %>

            <% } %>

        </section>
    </main>

    <%- include("../partials/menu"); %>

    <script src="js/script.js"></script>
    <script>
    (function(){
        "use strict";
        var state = { contrast: false, links: false, ruler: false, font: false, spacing: false, zoom: 100 };
        var ZOOM_MIN = 80, ZOOM_MAX = 200, ZOOM_STEP = 10;
        var STORAGE_KEY = "azup_a11y_state";
        var CLASS_MAP = {
            contrast: "azup-a11y-high-contrast",
            links: "azup-a11y-highlight-links",
            font: "azup-a11y-readable-font",
            spacing: "azup-a11y-spacing"
        };

        function loadState() {
            try {
                var saved = localStorage.getItem(STORAGE_KEY);
                if (saved) { 
                    var p = JSON.parse(saved); 
                    for (var k in p) { if (state.hasOwnProperty(k)) state[k] = p[k]; } 
                }
            } catch(e) {}
        }

        function saveState() {
            try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch(e) {}
        }

        function applyAll() {
            var body = document.body;
            for (var feat in CLASS_MAP) {
                body.classList.toggle(CLASS_MAP[feat], !!state[feat]);
            }
            document.documentElement.style.fontSize = state.zoom + "%";
            var lvl = document.getElementById("azup-a11y-zoom-level");
            if (lvl) lvl.textContent = state.zoom + "%";
            var ruler = document.getElementById("azup-a11y-reading-ruler");
            if (ruler) ruler.classList.toggle("azup-a11y-ruler-active", state.ruler);
            
            var allFeats = Object.keys(CLASS_MAP).concat(["ruler"]);
            allFeats.forEach(function(f) {
                var btn = document.querySelector("[data-feature=\"" + f + "\"]");
                if (btn) btn.setAttribute("aria-pressed", state[f] ? "true" : "false");
            });
            saveState();
        }

        function toggleFeature(feat) {
            if (state.hasOwnProperty(feat)) {
                state[feat] = !state[feat];
                applyAll();
            }
        }

        function resetAll() {
            state.contrast = false;
            state.links = false;
            state.ruler = false;
            state.font = false;
            state.spacing = false;
            state.zoom = 100;
            applyAll();
        }

        function togglePanel() {
            var toolbar = document.getElementById("azup-a11y-toolbar");
            var panel = document.getElementById("azup-a11y-panel");
            var toggle = document.getElementById("azup-a11y-toggle");
            if (!toolbar || !panel || !toggle) return;
            var expanded = toolbar.classList.contains("azup-a11y-expanded");
            toolbar.classList.toggle("azup-a11y-expanded");
            toolbar.classList.toggle("azup-a11y-collapsed");
            panel.setAttribute("aria-hidden", expanded ? "true" : "false");
            toggle.setAttribute("aria-expanded", expanded ? "false" : "true");
        }

        function onMouseMove(e) {
            if (state.ruler) {
                var ruler = document.getElementById("azup-a11y-reading-ruler");
                if (ruler) ruler.style.top = (e.clientY - 6) + "px";
            }
        }

        function init() {
            loadState();
            applyAll();
            var toggleBtn = document.getElementById("azup-a11y-toggle");
            var closeBtn = document.getElementById("azup-a11y-close");
            if (toggleBtn) toggleBtn.addEventListener("click", togglePanel);
            if (closeBtn) closeBtn.addEventListener("click", togglePanel);
            
            document.querySelectorAll("[data-feature]").forEach(function(btn) {
                btn.addEventListener("click", function() { toggleFeature(btn.getAttribute("data-feature")); });
            });
            
            var zoomUp = document.getElementById("azup-a11y-zoom-up");
            var zoomDown = document.getElementById("azup-a11y-zoom-down");
            if (zoomUp) zoomUp.addEventListener("click", function() { if (state.zoom < ZOOM_MAX) { state.zoom += ZOOM_STEP; applyAll(); } });
            if (zoomDown) zoomDown.addEventListener("click", function() { if (state.zoom > ZOOM_MIN) { state.zoom -= ZOOM_STEP; applyAll(); } });
            
            var resetBtn = document.getElementById("azup-a11y-reset");
            if (resetBtn) resetBtn.addEventListener("click", resetAll);
            
            document.addEventListener("mousemove", onMouseMove);
            document.addEventListener("keydown", function(e) {
                if (e.key === "Escape") {
                    var toolbar = document.getElementById("azup-a11y-toolbar");
                    if (toolbar && toolbar.classList.contains("azup-a11y-expanded")) togglePanel();
                }
                if (e.altKey && (e.key === "a" || e.key === "A")) { e.preventDefault(); togglePanel(); }
            });
        }

        if (document.readyState === "loading") { document.addEventListener("DOMContentLoaded", init); }
        else { init(); }
    })();
    </script>
</body>
</html>
