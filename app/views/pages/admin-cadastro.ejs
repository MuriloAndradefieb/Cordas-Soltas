<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cadastro - Cordas Soltas</title>
    <link rel="stylesheet" href="/css/admin-dashboard.css">
</head>
<body>

    <hr class="top-line">

    <header class="main-header">
        <img src="/img/LOGO ALTERNATIVA CORDAS SOLTAS SITE.png" width="50px" alt="Logo Cordas Soltas" class="logo">
    </header>

    <section class="app-container">
        
        <nav class="sidebar-nav">
            <ul>
                <li class="active"><img src="/img/perfil-icon.png" width="10px"> Cadastro</li>
                <li onclick="window.location.href='/adm/ingressos'"><img src="/img/ingressos-icon.png" width="10px"> Ingressos</li>
                <li><img src="/img/luthbox-icon.png" width="10px"> Luthbox</li>
                <li onclick="window.location.href='/adm/formularios'"><img src="/img/formulario-icon.png" width="10px"> Formul&aacute;rios</li>
            </ul>
        </nav>

        <main class="content-area">
            
            <header class="sub-header">
                <span class="title">CADASTRO</span>
                <button class="btn-add" type="button" onclick="window.location.href='/cadastro'"><span>+</span> Adicionar</button>
            </header>

            <section class="search-container">
                <button class="btn-search"><img src="/img/lupa.png" width="20px"></button>
            </section>

            <section class="user-section">
                <h2 class="category-title">Visitante</h2>
                <section class="table-container">
                    <table class="adm-table">
                        <thead>
                            <tr>
                                <th style="width: 45%;">E-MAIL</th>
                                <th style="width: 35%;">USUÁRIOS</th>
                                <th style="width: 20%;">AÇÕES</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (typeof visitantes !== 'undefined' && visitantes.length > 0) { %>
                                <% visitantes.forEach(function(visitante) { %>
                                    <tr>
                                        <td><span class="email-link"><%= visitante.email %></span></td>
                                        <td><%= visitante.username %></td>
                                        <td>
                                            <button class="btn-action" type="button" data-edit-url="/adm/visitantes/editar/<%= visitante.id %>"><img src="/img/confg.png" width="15px" fill="currentColor"></button>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="3" style="text-align: center; color: #999; font-style: italic; padding: 20px;">Nenhum visitante encontrado.</td>
                                </tr>
                            <% } %>
                            <tr class="empty-row"><td></td><td></td><td></td></tr>
                            <tr class="empty-row"><td></td><td></td><td></td></tr>
                        </tbody>
                    </table>
                </section>
            </section>

            <section class="user-section">
                <h2 class="category-title">Artista</h2>
                <section class="table-container">
                    <table class="adm-table">
                        <thead>
                            <tr>
                                <th style="width: 45%;">E-MAIL</th>
                                <th style="width: 35%;">BANDA</th>
                                <th style="width: 20%;">AÇÕES</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (typeof artistas !== 'undefined' && artistas.length > 0) { %>
                                <% artistas.forEach(function(artista) { %>
                                    <tr>
                                        <td><span class="email-link"><%= artista.email %></span></td>
                                        <td><%= artista.nome_banda || artista.username %></td>
                                        <td>
                                            <button class="btn-action" type="button" data-edit-url="/adm/artistas/editar/<%= artista.id %>"><img src="/img/confg.png" width="15px" fill="currentColor"></button>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="3" style="text-align: center; color: #999; font-style: italic; padding: 20px;">Nenhum artista encontrado.</td>
                                </tr>
                            <% } %>
                            <tr class="empty-row"><td></td><td></td><td></td></tr>
                            <tr class="empty-row"><td></td><td></td><td></td></tr>
                        </tbody>
                    </table>
                </section>
            </section>

        </main>
    </section>

    <script src="/js/admin-dashboard.js"></script>
</body>
</html>
