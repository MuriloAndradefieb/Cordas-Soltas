<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Luthbox - Equipamentos por Estilo</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Odibee+Sans&family=Roboto:wght@400;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="css/style.css">

    <style>
        /* ── Reset base ─────────────────────────────────── */
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background-color: #121212;
            color: #fff;
            font-family: 'Roboto', sans-serif;
            background-image: none;
        }

        /* ── Wrapper principal ──────────────────────────── */
        .luth-page {
            max-width: 420px;
            margin: 0 auto;
            padding: 0 0 60px;
        }

        /* ── Cabeçalho ──────────────────────────────────── */
        .luth-header {
            text-align: center;
            padding: 28px 16px 18px;
        }

        .luth-header__title {
            font-family: 'Odibee Sans', sans-serif;
            font-size: 3.2rem;
            font-weight: 400;
            color: #F9AF11;
            line-height: 1;
            letter-spacing: 1px;
        }

        .luth-header__subtitle {
            font-size: 0.85rem;
            font-weight: 400;
            color: #ffffff;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-top: 2px;
        }

        /* ── Grade 2 colunas ───────────────────────────── */
        .luth-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            padding: 0 10px;
        }

        /* Samba fica centralizado na última linha */
        .luth-grid .luth-card:last-child:nth-child(odd) {
            grid-column: 1 / -1;
            max-width: 50%;
            margin: 0 auto;
            width: 100%;
        }

        /* ── Card ───────────────────────────────────────── */
        .luth-card {
            background-color: #141414;
            border: 1px solid #2a2a2a;
            border-radius: 6px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        /* Cabeçalho do card (título do estilo) */
        .luth-card__style-name {
            font-family: 'Odibee Sans', sans-serif;
            font-size: 1.35rem;
            font-weight: 400;
            color: #F9AF11;
            text-align: center;
            padding: 8px 6px 4px;
            text-transform: uppercase;
            letter-spacing: 1px;
            background-color: #0d0d0d;
        }

        /* Imagem */
        .luth-card__img {
            width: 100%;
            height: 140px;
            object-fit: cover;
            display: block;
        }

        /* Corpo do card */
        .luth-card__body {
            padding: 10px 12px 12px;
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .luth-card__desc-label {
            font-size: 0.78rem;
            color: #F9AF11;
            font-weight: 700;
            letter-spacing: 0.5px;
            margin-bottom: 6px;
            text-transform: lowercase;
        }

        .luth-card__list {
            list-style: none;
            padding: 0;
            flex: 1;
        }

        .luth-card__list li {
            font-size: 0.82rem;
            color: #e0e0e0;
            line-height: 1.65;
        }

        .luth-card__list li::before {
            content: attr(data-qty) 'x ';
            color: #e0e0e0;
        }

        .luth-card__price {
            font-size: 0.8rem;
            color: #b0b0b0;
            margin-top: 8px;
        }

        /* ── Botão assinar ─────────────────────────────── */
        .luth-card__btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 7px;
            width: 100%;
            background-color: #1c1c1c;
            border: 1px solid #333;
            color: #ffffff;
            font-family: 'Roboto', sans-serif;
            font-size: 0.85rem;
            font-weight: 700;
            padding: 11px 0;
            cursor: pointer;
            margin-top: 12px;
            border-radius: 3px;
            text-decoration: none;
            transition: background-color 0.2s, border-color 0.2s;
        }

        .luth-card__btn:hover {
            background-color: #F9AF11;
            border-color: #F9AF11;
            color: #000;
        }

        .luth-card__btn-icon {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 18px;
            height: 18px;
            background-color: #F9AF11;
            border-radius: 2px;
            flex-shrink: 0;
        }

        .luth-card__btn:hover .luth-card__btn-icon {
            background-color: #000;
        }

        .luth-card__btn-icon svg {
            width: 11px;
            height: 11px;
            fill: #000;
        }

        .luth-card__btn:hover .luth-card__btn-icon svg {
            fill: #F9AF11;
        }

        /* ── Footer ─────────────────────────────────────── */
        .luth-footer {
            text-align: center;
            padding: 24px 16px 12px;
            font-size: 0.7rem;
            color: #666;
            border-top: 1px solid #1e1e1e;
            margin-top: 30px;
            line-height: 1.7;
        }
    </style>
</head>
<body class="luthbox-seguros-page">

    <!-- Plugin VLibras — não remover -->
