<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= show ? 'Ingressos > Editar' : 'Ingressos > Adicionar' %> - Cordas Soltas</title>
    <link rel="stylesheet" href="/css/admin-dashboard.css">
    <style>
        .painel-cadastro {
            background-color: #333333;
            border-radius: 4px;
            padding: 40px;
            width: 100%;
            max-width: 950px;
            margin: 0 auto;
            display: block;
        }

        .grid-formulario {
            display: flex;
            gap: 40px;
            align-items: stretch;
        }

        .coluna-banner-lateral {
            flex: 1.1;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .coluna-campos-laterais {
            flex: 1.2;
            display: flex;
            flex-direction: column;
            gap: 20px;
            justify-content: space-between;
        }

        .grupo-input {
            border: none;
            padding: 0;
            margin: 0;
            display: flex;
            flex-direction: column;
            gap: 6px;
            position: relative;
        }

        .grupo-input label {
            color: #ffb800;
            font-size: 16px;
            font-weight: 600;
            font-family: sans-serif;
        }

        .grupo-input input,
        .grupo-input select {
            background-color: #404040;
            border: none;
            color: #ffffff;
            padding: 12px 15px;
            border-radius: 10px;
            font-size: 15px;
            width: 100%;
            box-sizing: border-box;
        }

        .grupo-input select {
            height: 45px;
            cursor: pointer;
            -webkit-appearance: none;
            -moz-appearance: none;
            appearance: none;
            background-image: url("data:image/svg+xml;utf8,<svg fill='%23ffb800' height='24' viewBox='0 0 24 24' width='24' xmlns='http://www.w3.org/2000/svg'><path d='M7 10l5 5 5-5z'/><path d='M0 0h24v24H0z' fill='none'/></svg>");
            background-repeat: no-repeat;
            background-position: right 12px top 50%;
        }

        .icone-edicao {
            position: absolute;
            right: 15px;
            bottom: 12px;
            color: #ffb800;
            font-size: 14px;
            pointer-events: none;
        }

        .container-upload-poster {
            width: 100%;
            flex: 1;
            min-height: 380px;
            background-color: #404040;
            border-radius: 8px;
            display: flex;
            justify-content: center;
            align-items: center;
            cursor: pointer;
            position: relative;
            overflow: hidden;
            border: 2px dashed #555555;
            transition: border-color 0.3s;
        }

        .container-upload-poster:hover {
            border-color: #ffb800;
        }

        .botao-adicionar-banner {
            background-color: #4c4c4c;
            border: 1px solid #666;
            color: #a6a6a6;
            padding: 12px 20px;
            border-radius: 10px;
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 10px;
            pointer-events: none;
            z-index: 2;
        }

        .botao-adicionar-banner svg {
            fill: #a6a6a6;
            width: 18px;
            height: 18px;
        }

        .img-preview-render {
            width: 100%;
            height: 100%;
            object-fit: cover;
            position: absolute;
            top: 0;
            left: 0;
            display: none;
            z-index: 1;
        }

        .container-botoes-topo {
            display: flex;
            justify-content: flex-end;
            gap: 20px;
            margin-bottom: 20px;
            width: 100%;
            max-width: 950px;
            margin-left: auto;
            margin-right: auto;
        }

        .btn-topo-cancela {
            background: transparent;
            border: 1px solid #ffb800;
            color: #ffffff;
            padding: 8px 20px;
            border-radius: 6px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 15px;
        }

        .btn-topo-salvar {
            background-color: #ffb800;
            border: none;
            color: #1a1a1a;
            padding: 8px 25px;
            border-radius: 6px;
            font-weight: bold;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 15px;
        }

        .btn-topo-salvar:hover {
            background-color: #e6a600;
        }

        input[type="date"]::-webkit-calendar-picker-indicator {
            filter: invert(77%) sepia(85%) saturate(1243%) hue-rotate(359deg) brightness(102%) contrast(106%);
            cursor: pointer;
        }

        #modal_exclusao {
            position: fixed !important;
            top: 50% !important;
            left: 50% !important;
            transform: translate(-50%, -50%) !important;
            margin: 0 !important;
            background-color: #1e1e1e !important;
            border: 1px solid #ffb800 !important;
            border-radius: 8px !important;
            padding: 30px !important;
            max-width: 450px !important;
            width: 90% !important;
            text-align: center !important;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.8) !important;
            z-index: 100000 !important;
        }

        #modal_exclusao::backdrop {
            background-color: rgba(0, 0, 0, 0.6) !important;
            backdrop-filter: blur(3px) !important;
        }
    </style>
</head>
<body>

    <hr class="top-line">

    <header class="main-header">
        <h2>CORDAS SOLTAS</h2>
    </header>

    <section class="app-container">
        
        <nav class="sidebar-nav">
            <ul>
                <li onclick="window.location.href='/adm/acesso-direto'"><img src="img/adm-icon.png" width="15px"> Administradores</li>
                <li onclick="window.location.href='/adm/cadastro'"><img src="img/perfil-icon.png" width="15px"> Cadastro</li>
                <li class="active" onclick="window.location.href='/adm/ingressos'"><img src="img/ingressos-icon.png" width="15px"> Ingressos</li>
                <li><img src="img/luthbox-icon.png" width="15px"> Luthbox</li>
            </ul>
        </nav>

        <main class="content-area">
            
            <form action="<%= show ? '/adm/ingressos/editar/' + show.id : '/adm/ingressos/adicionar' %>" method="POST" enctype="multipart/form-data">

                <header class="sub-header" style="background: transparent; padding: 0; margin-bottom: 5px;">
                    <span class="title" style="font-size: 14px; color: #b3b3b3; font-weight: normal;">
                        Ingressos &gt; <%= show ? 'Editar' : 'Adicionar' %>
                    </span>
                </header>

                <section class="container-botoes-topo">
                    <button type="button" class="btn-topo-cancela" onclick="window.location.href='/adm/ingressos'">
                        <span style="color: #ff4a4a; font-weight: bold;">✕</span> Cancelar
                    </button>
                    <button type="submit" class="btn-topo-salvar">
                        <img src="img/salvar-icon.png" width="15px"> Salvar
                    </button>
                </section>

                <section class="painel-cadastro">
                    <section class="grid-formulario">
                        
                        <aside class="coluna-banner-lateral">
                            <div class="grupo-input" style="height: 100%;">
                                <label>Banner do Pôster</label>
                                <label for="file_upload" class="container-upload-poster" style="<%= (show && show.imagem_url) ? 'border: none;' : '' %>">
                                    
                                    <section class="botao-adicionar-banner" id="wrapper_botao_upload" style="<%= (show && show.imagem_url) ? 'display: none;' : '' %>">
                                        <svg viewBox="0 0 24 24"><path d="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96zM14 13v4h-4v-4H7l5-5 5 5h-3z"/></svg>
                                        Adicionar banner
                                    </section>
                                    
                                    <img src="<%= show ? (show.imagem_url || '/img/pexels-wendywei-1190297.jpg') : '' %>" id="render_preview" class="img-preview-render" alt="Preview do Banner" style="<%= (show && show.imagem_url) ? 'display: block;' : '' %>" onerror="this.onerror=null;this.src='/img/pexels-wendywei-1190297.jpg';">
                                </label>
                                <input type="file" id="file_upload" name="image_file" accept="image/*" style="display: none;" <%= show ? '' : 'required' %>>
                            </div>
                        </aside>

                        <aside class="coluna-campos-laterais">
                            
                            <fieldset class="grupo-input">
                                <label for="titulo">Show</label>
                                <input type="text" id="titulo" name="titulo" placeholder="Ex: Rock" value="<%= show ? show.titulo : '' %>" required>
                            </fieldset>

                            <fieldset class="grupo-input">
                                <label for="estilo">Estilo Musical</label>
                                <select id="estilo" name="estilo" required>
                                    <% estilos.forEach(function(estiloItem) { %>
                                        <option value="<%= estiloItem %>" <%= (show && show.estilo === estiloItem) ? 'selected' : '' %>><%= estiloItem %></option>
                                    <% }); %>
                                </select>
                            </fieldset>

                            <fieldset class="grupo-input">
                                <label for="preco">Preço</label>
                                <input type="text" id="preco" name="preco" placeholder="R$ 0,00" value="<%= show ? show.preco : '' %>" onblur="formatarPrecoInteiro(this)" inputmode="decimal" maxlength="14" required>
                                <span class="icone-edicao">📝</span>
                            </fieldset>

                            <fieldset class="grupo-input">
                                <label for="quantidade">Quantidade de Ingressos</label>
                                <input type="number" id="quantidade" name="quantidade" min="1" placeholder="Ex: 50" value="<%= show ? show.quantidade : '' %>" required>
                            </fieldset>

                            <fieldset class="grupo-input">
                                <label for="data_show">Data</label>
                                <input type="date" id="data_show" name="data_show" value="<%= show ? show.data_show : '' %>" required>
                            </fieldset>

                            <fieldset class="grupo-input">
                                <label for="local">Local</label>
                                <input type="text" id="local" name="local" placeholder="Ex: Praças das Artes-SP" value="<%= show ? show.local : '' %>" required>
                                <span class="icone-edicao">📝</span>
                            </fieldset>

                        </aside>

                    </section>
                </section>

            </form>

        </main>
    </section>

    <script>
        const inputUpload = document.getElementById('file_upload');
        const imagemRender = document.getElementById('render_preview');
        const botaoUpload = document.getElementById('wrapper_botao_upload');
        const containerUpload = document.querySelector('.container-upload-poster');

        inputUpload.addEventListener('change', function(e) {
            const arquivo = e.target.files[0];
            if (arquivo) {
                const leitor = new FileReader();
                leitor.onload = function(event) {
                    imagemRender.src = event.target.result;
                    imagemRender.style.display = 'block';
                    botaoUpload.style.display = 'none';
                    containerUpload.style.border = 'none';
                }
                leitor.readAsDataURL(arquivo);
            }
        });
      
        function formatarPrecoInteiro(campo) {
            let valor = campo.value;

            // 1. Remove o "R$ " para fazer os cálculos limpos
            valor = valor.replace(/^R\$\s?/, "");

            if (valor === "") {
                campo.value = "";
                return;
            }

            // 2. Permite apenas números e uma única vírgula para os centavos
            valor = valor.replace(/[^\d,]/g, "");
            
            let partes = valor.split(",");
            let parteInteira = partes[0];
            let parteDecimal = partes.length > 1 ? "," + partes[1].slice(0, 2) : "";

            // TRAVA DE SEGURANÇA: Limita a parte puramente inteira a 7 dígitos (máximo de 9.999.999)
            // Isso evita que o usuário digite trilhões e cause erro interno no banco de dados.
            if (parteInteira.length > 7) {
                parteInteira = parteInteira.slice(0, 7);
            }

            // 3. Coloca os pontos de milhar apenas (ex: 2340 vira 2.340)
            parteInteira = parteInteira.replace(/\D/g, ""); 
            if (parteInteira !== "") {
                parteInteira = parseInt(parteInteira, 10).toString(); // Tira zeros à esquerda
                parteInteira = parteInteira.replace(/(\d)(?=(\d{3})+(?!\d))/g, "$1.");
            } else {
                parteInteira = "0";
            }

            // 4. Devolve o valor formatado para a tela do usuário
            campo.value = "R$ " + parteInteira + parteDecimal;
        }

        function normalizarPreco(valor) {
            valor = String(valor || "")
                .trim()
                .replace(/^R\$\s?/, "")
                .replace(/\s/g, "")
                .replace(/[^\d.,]/g, "");

            if (!valor) return NaN;

            const temVirgula = valor.includes(",");
            const temPonto = valor.includes(".");

            if (temVirgula) {
                valor = valor.replace(/\./g, "").replace(",", ".");
            } else if (temPonto) {
                const partes = valor.split(".");
                const ultimaParte = partes[partes.length - 1];
                valor = partes.length === 2 && ultimaParte.length <= 2
                    ? valor
                    : valor.replace(/\./g, "");
            }

            return Number.parseFloat(valor);
        }

        function formatarPrecoInteiro(campo) {
            const numero = normalizarPreco(campo.value);

            if (!campo.value.trim()) {
                campo.value = "";
                return;
            }

            if (!Number.isFinite(numero)) {
                campo.value = "";
                return;
            }

            campo.value = numero.toLocaleString("pt-BR", {
                style: "currency",
                currency: "BRL",
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            });
        }

        // Quando a página carregar (no modo editar), formata o valor que veio do banco
        document.addEventListener("DOMContentLoaded", function() {
            const campo = document.getElementById("preco");
            if(campo && campo.value) {
                formatarPrecoInteiro(campo);
            }

            // TRUQUE PARA SALVAR SEM ERRO: intercepta o envio do formulário
            const formulario = campo.closest("form");
            if (formulario) {
                formulario.addEventListener("submit", function() {
                    // Antes de enviar, remove "R$ ", tira os pontos de milhar e troca a vírgula por ponto decimal pro banco aceitar
                    let valorLimpo = campo.value.replace(/^R\$\s?/, "").replace(/\./g, "").replace(",", ".");
                    campo.value = valorLimpo; // Envia o número limpo (ex: 2340 ou 200.00)
                });
            }
        });
    </script>
</body>
</html>
