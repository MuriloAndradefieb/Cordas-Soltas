<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ingressos > Adicionar - Cordas Soltas</title>
    <link rel="stylesheet" href="/css/admin-dashboard.css">
    <style>
        /* Painel escentralizado e expandido baseado na última versão */
        .painel-cadastro {
            background-color: #333333;
            border-radius: 4px;
            padding: 40px;
            width: 100%;
            max-width: 950px;
            margin: 0 auto;
            display: block;
        }

        /* Estrutura de colunas voltando ao design original (Banner na esquerda, Campos na direita) */
        .grid-formulario {
            display: flex;
            gap: 40px;
            align-items: stretch; /* Garante que as duas colunas fiquem com a mesma altura */
        }

        /* Coluna da Esquerda: Destinada ao Banner Grande */
        .coluna-banner-lateral {
            flex: 1.1;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        /* Coluna da Direita: Destinada aos inputs do formulário */
        .coluna-campos-laterais {
            flex: 1.2;
            display: flex;
            flex-direction: column;
            gap: 20px;
            justify-content: space-between; /* Distribui os campos uniformemente acompanhando a altura do banner */
        }

        /* Estilização dos Grupos de Input */
        .grupo-input {
            border: none;
            padding: 0;
            margin: 0;
            display: flex;
            flex-direction: column;
            gap: 6px;
            position: relative;
        }

        .grupo-input label {
            color: #ffb800;
            font-size: 16px;
            font-weight: 600;
            font-family: sans-serif;
        }

        .grupo-input input,
        .grupo-input select {
            background-color: #404040;
            border: none;
            color: #ffffff;
            padding: 12px 15px;
            border-radius: 10px; /* Bordas arredondadas originais */
            font-size: 15px;
            width: 100%;
            box-sizing: border-box;
        }

        /* Customização do Select de Estilo Musical */
        .grupo-input select {
            height: 45px;
            cursor: pointer;
            -webkit-appearance: none;
            -moz-appearance: none;
            appearance: none;
            background-image: url("data:image/svg+xml;utf8,<svg fill='%23ffb800' height='24' viewBox='0 0 24 24' width='24' xmlns='http://www.w3.org/2000/svg'><path d='M7 10l5 5 5-5z'/><path d='M0 0h24v24H0z' fill='none'/></svg>");
            background-repeat: no-repeat;
            background-position: right 12px top 50%;
        }

        /* Ícone decorativo de edição */
        .icone-edicao {
            position: absolute;
            right: 15px;
            bottom: 12px;
            color: #ffb800;
            font-size: 14px;
            pointer-events: none;
        }

        /* Área do Banner Lateral Ampliada e Estilizada */
        .container-upload-poster {
            width: 100%;
            flex: 1; /* Faz o container ocupar toda a altura disponível da coluna */
            min-height: 380px; /* Garante que ele seja grande e imponente */
            background-color: #404040;
            border-radius: 8px;
            display: flex;
            justify-content: center;
            align-items: center;
            cursor: pointer;
            position: relative;
            overflow: hidden;
            border: 2px dashed #555555;
            transition: border-color 0.3s;
        }

        .container-upload-poster:hover {
            border-color: #ffb800;
        }

        /* Botão interno do Upload */
        .botao-adicionar-banner {
            background-color: #4c4c4c;
            border: 1px solid #666;
            color: #a6a6a6;
            padding: 12px 20px;
            border-radius: 10px;
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 10px;
            pointer-events: none;
            z-index: 2;
        }

        .botao-adicionar-banner svg {
            fill: #a6a6a6;
            width: 18px;
            height: 18px;
        }

        /* Renderização da Imagem selecionada do computador */
        .img-preview-render {
            width: 100%;
            height: 100%;
            object-fit: cover;
            position: absolute;
            top: 0;
            left: 0;
            display: none;
            z-index: 1;
        }

        /* Botões superiores de ação */
        .container-botoes-topo {
            display: flex;
            justify-content: flex-end;
            gap: 20px;
            margin-bottom: 20px;
            width: 100%;
            max-width: 950px;
            margin-left: auto;
            margin-right: auto;
        }

        .btn-topo-cancela {
            background: transparent;
            border: 1px solid #ffb800;
            color: #ffffff;
            padding: 8px 20px;
            border-radius: 6px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 15px;
        }

        .btn-topo-salvar {
            background-color: #ffb800;
            border: none;
            color: #1a1a1a;
            padding: 8px 25px;
            border-radius: 6px;
            font-weight: bold;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 15px;
        }

        .btn-topo-salvar:hover {
            background-color: #e6a600;
        }

        /* Ajuste do ícone do input de data */
        input[type="date"]::-webkit-calendar-picker-indicator {
            filter: invert(77%) sepia(85%) saturate(1243%) hue-rotate(359deg) brightness(102%) contrast(106%);
            cursor: pointer;
        }
    </style>
</head>
<body>

    <hr class="top-line">

    <header class="main-header">
        <h2>CORDAS SOLTAS</h2>
    </header>

    <section class="app-container">
        
        <nav class="sidebar-nav">
            <ul>
                <li onclick="window.location.href='/adm/acesso-direto'">⚙️ Administradores</li>
                <li onclick="window.location.href='/adm/cadastro'">👤 Cadastro</li>
                <li class="active" onclick="window.location.href='/adm/ingressos'">🎫 Ingressos</li>
                <li>🧰 Luthbox</li>
            </ul>
        </nav>

        <main class="content-area">
            
            <form action="/adm/ingressos/adicionar" method="POST" enctype="multipart/form-data">

                <header class="sub-header" style="background: transparent; padding: 0; margin-bottom: 5px;">
                    <span class="title" style="font-size: 14px; color: #b3b3b3; font-weight: normal;">Ingressos > Adicionar</span>
                </header>

                <section class="container-botoes-topo">
                    <button type="button" class="btn-topo-cancela" onclick="window.location.href='/adm/ingressos'">
                        <span style="color: #ff4a4a; font-weight: bold;">✕</span> Cancela
                    </button>
                    <button type="submit" class="btn-topo-salvar">
                        💾 Salvar
                    </button>
                </section>

                <section class="painel-cadastro">
                    <section class="grid-formulario">
                        
                        <aside class="coluna-banner-lateral">
                            <div class="grupo-input" style="height: 100%;">
                                <label>Banner do Pôster</label>
                                <label for="file_upload" class="container-upload-poster">
                                    <section class="botao-adicionar-banner" id="wrapper_botao_upload">
                                        <svg viewBox="0 0 24 24"><path d="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96zM14 13v4h-4v-4H7l5-5 5 5h-3z"/></svg>
                                        Adicionar banner
                                    </section>
                                    <img src="" id="render_preview" class="img-preview-render" alt="Preview do Banner">
                                </label>
                                <input type="file" id="file_upload" name="image_file" accept="image/*" style="display: none;" required>
                            </div>
                        </aside>

                        <aside class="coluna-campos-laterais">
                            
                            <fieldset class="grupo-input">
                                <label for="titulo">Show</label>
                                <input type="text" id="titulo" name="titulo" placeholder="Ex: Rock" required>
                            </fieldset>

                            <fieldset class="grupo-input">
                                <label for="estilo">Estilo Musical</label>
                                <select id="estilo" name="estilo" required>
                                    <% estilos.forEach(function(estiloItem) { %>
                                        <option value="<%= estiloItem %>"><%= estiloItem %></option>
                                    <% }); %>
                                </select>
                            </fieldset>

                            <fieldset class="grupo-input">
                                <label for="preco">Preço</label>
                                <input type="number" id="preco" name="preco" step="0.01" min="0" placeholder="R$ 00,00" required>
                                <span class="icone-edicao">📝</span>
                            </fieldset>

                            <fieldset class="grupo-input">
                                <label for="quantidade">Quantidade de Ingressos</label>
                                <input type="number" id="quantidade" name="quantidade" min="1" placeholder="Ex: 50" required>
                            </fieldset>

                            <fieldset class="grupo-input">
                                <label for="data_show">Data</label>
                                <input type="date" id="data_show" name="data_show" required>
                            </fieldset>

                            <fieldset class="grupo-input">
                                <label for="local">Local</label>
                                <input type="text" id="local" name="local" placeholder="Ex: Praças das Artes-SP" required>
                                <span class="icone-edicao">📝</span>
                            </fieldset>

                        </aside>

                    </section>
                </section>

            </form>

        </main>
    </section>

    <script>
        const inputUpload = document.getElementById('file_upload');
        const imagemRender = document.getElementById('render_preview');
        const botaoUpload = document.getElementById('wrapper_botao_upload');
        const containerUpload = document.querySelector('.container-upload-poster');

        inputUpload.addEventListener('change', function(e) {
            const arquivo = e.target.files[0];
            if (arquivo) {
                const leitor = new FileReader();
                leitor.onload = function(event) {
                    imagemRender.src = event.target.result;
                    imagemRender.style.display = 'block';
                    botaoUpload.style.display = 'none';
                    containerUpload.style.border = 'none'; // Remove a borda pontilhada quando a foto entra
                }
                leitor.readAsDataURL(arquivo);
            }
        });
    </script>
</body>
</html>