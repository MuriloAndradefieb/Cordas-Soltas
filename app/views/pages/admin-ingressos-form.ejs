<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= show ? 'Ingressos > Editar' : 'Ingressos > Adicionar' %> - Cordas Soltas</title>
    <link rel="stylesheet" href="/css/admin-dashboard.css">
</head>
<body class="admin-ingressos-form-page">

    <hr class="top-line">

    <header class="main-header">
        <img src="/img/LOGO ALTERNATIVA CORDAS SOLTAS SITE.png" width="50px" alt="Logo Cordas Soltas" class="logo">
    </header>

    <section class="app-container">
        
        <nav class="sidebar-nav">
            <ul>
                <li onclick="window.location.href='/adm/cadastro'"><img src="/img/perfil-icon.png" width="10px"> Cadastro</li>
                <li class="active" onclick="window.location.href='/adm/ingressos'"><img src="/img/ingressos-icon.png" width="10px"> Ingressos</li>
                <li><img src="/img/luthbox-icon.png" width="10px"> Luthbox</li>
            </ul>
        </nav>

        <main class="content-area">
            
            <form action="<%= show ? '/adm/ingressos/editar/' + show.id : '/adm/ingressos/adicionar' %>" method="POST" enctype="multipart/form-data">

                <header class="sub-header">
                    <span class="title">
                        Ingressos &gt; <%= show ? 'Editar' : 'Adicionar' %>
                    </span>
                </header>

                <section class="container-botoes-topo">
                    <button type="button" class="btn-topo-cancela" onclick="window.location.href='/adm/ingressos'">
                        <span class="btn-cancel-icon"><img src="/img/x-icon.png" width="20px"></span> Cancelar
                    </button>
                    <button type="submit" class="btn-topo-salvar">
                        <img src="/img/salvar-icon.png" width="20px"> Salvar
                    </button>
                </section>

                <section class="painel-cadastro">
                    <section class="grid-formulario">
                        
                        <aside class="coluna-banner-lateral">
                            <div class="grupo-input grupo-upload">
                                <label>Banner do Pôster</label>
                                <label for="file_upload" class="container-upload-poster <%= (show && show.imagem_url) ? 'has-preview' : '' %>">
                                    
                                    <section class="botao-adicionar-banner <%= (show && show.imagem_url) ? 'is-hidden' : '' %>" id="wrapper_botao_upload">
                                        <svg viewBox="0 0 24 24"><path d="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96zM14 13v4h-4v-4H7l5-5 5 5h-3z"/></svg>
                                        Adicionar banner
                                    </section>
                                    
                                    <img src="<%= show ? (show.imagem_url || '/img/pexels-wendywei-1190297.jpg') : '' %>" id="render_preview" class="img-preview-render <%= (show && show.imagem_url) ? 'is-visible' : '' %>" alt="Preview do Banner" onerror="this.onerror=null;this.src='/img/pexels-wendywei-1190297.jpg';">
                                </label>
                                <input type="file" id="file_upload" name="image_file" accept="image/*" style="display: none;" <%= show ? '' : 'required' %>>
                            </div>
                        </aside>

                        <aside class="coluna-campos-laterais">
                            
                            <fieldset class="grupo-input">
                                <label for="titulo">Show</label>
                                <input type="text" id="titulo" name="titulo" placeholder="Ex: Rock" value="<%= show ? show.titulo : '' %>" required>
                            </fieldset>

                            <fieldset class="grupo-input">
                                <label for="estilo">Estilo Musical</label>
                                <select id="estilo" name="estilo" required>
                                    <% estilos.forEach(function(estiloItem) { %>
                                        <option value="<%= estiloItem %>" <%= (show && show.estilo === estiloItem) ? 'selected' : '' %>><%= estiloItem %></option>
                                    <% }); %>
                                </select>
                            </fieldset>

                            <fieldset class="grupo-input">
                                <label for="preco">Preço</label>
                                <input type="text" id="preco" name="preco" placeholder="R$ 0,00" value="<%= show ? show.preco : '' %>" onblur="formatarPrecoInteiro(this)" inputmode="decimal" maxlength="14" required>
                                <span class="icone-edicao"><img src="/img/confg.png" width="20px"></span>
                            </fieldset>

                            <fieldset class="grupo-input">
                                <label for="quantidade">Quantidade de Ingressos</label>
                                <input type="number" id="quantidade" name="quantidade" min="1" placeholder="Ex: 50" value="<%= show ? show.quantidade : '' %>" required>
                            </fieldset>

                            <fieldset class="grupo-input">
                                <label for="data_show">Data</label>
                                <input type="date" id="data_show" name="data_show" value="<%= show ? show.data_show : '' %>" required>
                            </fieldset>

                            <fieldset class="grupo-input">
                                <label for="local">Local</label>
                                <input type="text" id="local" name="local" placeholder="Ex: Praças das Artes-SP" value="<%= show ? show.local : '' %>" required>
                                <span class="icone-edicao"><img src="/img/confg.png" width="20px"></span>
                            </fieldset>

                        </aside>

                    </section>
                </section>

            </form>

        </main>
    </section>

    <script>
        const inputUpload = document.getElementById('file_upload');
        const imagemRender = document.getElementById('render_preview');
        const botaoUpload = document.getElementById('wrapper_botao_upload');
        const containerUpload = document.querySelector('.container-upload-poster');

        inputUpload.addEventListener('change', function(e) {
            const arquivo = e.target.files[0];
            if (arquivo) {
                const leitor = new FileReader();
                leitor.onload = function(event) {
                    imagemRender.src = event.target.result;
                    imagemRender.classList.add('is-visible');
                    botaoUpload.classList.add('is-hidden');
                    containerUpload.classList.add('has-preview');
                }
                leitor.readAsDataURL(arquivo);
            }
        });
      
        function formatarPrecoInteiro(campo) {
            let valor = campo.value;

            // 1. Remove o "R$ " para fazer os cálculos limpos
            valor = valor.replace(/^R\$\s?/, "");

            if (valor === "") {
                campo.value = "";
                return;
            }

            // 2. Permite apenas números e uma única vírgula para os centavos
            valor = valor.replace(/[^\d,]/g, "");
            
            let partes = valor.split(",");
            let parteInteira = partes[0];
            let parteDecimal = partes.length > 1 ? "," + partes[1].slice(0, 2) : "";

            // TRAVA DE SEGURANÇA: Limita a parte puramente inteira a 7 dígitos (máximo de 9.999.999)
            // Isso evita que o usuário digite trilhões e cause erro interno no banco de dados.
            if (parteInteira.length > 7) {
                parteInteira = parteInteira.slice(0, 7);
            }

            // 3. Coloca os pontos de milhar apenas (ex: 2340 vira 2.340)
            parteInteira = parteInteira.replace(/\D/g, ""); 
            if (parteInteira !== "") {
                parteInteira = parseInt(parteInteira, 10).toString(); // Tira zeros à esquerda
                parteInteira = parteInteira.replace(/(\d)(?=(\d{3})+(?!\d))/g, "$1.");
            } else {
                parteInteira = "0";
            }

            // 4. Devolve o valor formatado para a tela do usuário
            campo.value = "R$ " + parteInteira + parteDecimal;
        }

        function normalizarPreco(valor) {
            valor = String(valor || "")
                .trim()
                .replace(/^R\$\s?/, "")
                .replace(/\s/g, "")
                .replace(/[^\d.,]/g, "");

            if (!valor) return NaN;

            const temVirgula = valor.includes(",");
            const temPonto = valor.includes(".");

            if (temVirgula) {
                valor = valor.replace(/\./g, "").replace(",", ".");
            } else if (temPonto) {
                const partes = valor.split(".");
                const ultimaParte = partes[partes.length - 1];
                valor = partes.length === 2 && ultimaParte.length <= 2
                    ? valor
                    : valor.replace(/\./g, "");
            }

            return Number.parseFloat(valor);
        }

        function formatarPrecoInteiro(campo) {
            const numero = normalizarPreco(campo.value);

            if (!campo.value.trim()) {
                campo.value = "";
                return;
            }

            if (!Number.isFinite(numero)) {
                campo.value = "";
                return;
            }

            campo.value = numero.toLocaleString("pt-BR", {
                style: "currency",
                currency: "BRL",
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            });
        }

        // Quando a página carregar (no modo editar), formata o valor que veio do banco
        document.addEventListener("DOMContentLoaded", function() {
            const campo = document.getElementById("preco");
            if(campo && campo.value) {
                formatarPrecoInteiro(campo);
            }

            // TRUQUE PARA SALVAR SEM ERRO: intercepta o envio do formulário
            const formulario = campo.closest("form");
            if (formulario) {
                formulario.addEventListener("submit", function() {
                    // Antes de enviar, remove "R$ ", tira os pontos de milhar e troca a vírgula por ponto decimal pro banco aceitar
                    let valorLimpo = campo.value.replace(/^R\$\s?/, "").replace(/\./g, "").replace(",", ".");
                    campo.value = valorLimpo; // Envia o número limpo (ex: 2340 ou 200.00)
                });
            }
        });
    </script>
</body>
</html>
