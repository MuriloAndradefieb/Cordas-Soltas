<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Adicionar Administrador - Cordas Soltas</title>
    <link rel="stylesheet" href="/css/admin-add.css">
</head>
<body>

    <span class="top-line"></span>

    <header class="main-header">
        <section class="logo-container">
            <h2 style="color: white; font-style: italic; letter-spacing: 1px;">CORDAS SOLTAS</h2>
        </section>
    </header>

    <section class="app-container">
        
        <aside class="sidebar">
            <nav>
                <ul>
                    <li><img src="/img/perfil-icon.png" width="15px"> Cadastro</li>
                    <li><img src="/img/ingressos-icon.png" width="15px"> Ingressos</li>
                    <li><img src="/img/luthbox-icon.png" width="15px"> Luthbox</li>
                    <li onclick="window.location.href='/adm/formularios'"><img src="/img/formulario-icon.png" width="15px"> Formul&aacute;rios</li>
                </ul>
            </nav>
        </aside>

        <main class="content-area">
            
            <header class="sub-header">
                <nav class="breadcrumb"><img src="adm-icon.png" width="15px"> Administradores > Adicionar</nav>
                <h1 class="title">ADMINISTRADORES</h1>
            </header>

            <% if (erro) { %>
                <article class="alert alert-error"><%= erro %></article>
            <% } %>
            <% if (sucesso) { %>
                <article class="alert alert-success"><%= sucesso %></article>
            <% } %>

            <form action="/adm/administradores/adicionar" method="POST" id="form-add-admin">
                
                <section class="action-bar">
                    <button type="button" id="btn-cancel" class="btn-cancel"><img src="/img/x-icon.png" width="15px"> Cancelar</button>
                    <button type="submit" class="btn-save"><img src="/img/salvar-icon.png" width="15px"> Salvar</button>
                </section>

                <fieldset class="form-card" style="border: none; padding: 0; margin: 0;">
                    
                    <section class="form-group">
                        <label>Nome</label>
                        <input type="text" name="nome" placeholder="nome" required>
                    </section>

                    <section class="form-group">
                        <label>E-mail</label>
                        <input type="email" name="email" placeholder="e-mail" required>
                    </section>

                    <section class="form-group">
                        <label>Usuário</label>
                        <input type="text" name="usuario" placeholder="usuário" required>
                    </section>

                    <section class="form-group">
                        <label>Senha</label>
                        <input type="password" name="senha" placeholder="Senha" required>
                    </section>

                    <section class="form-group">
                        <label>Adm Geral</label>
                        <section class="radio-container">
                            <label class="radio-label">
                                <input type="radio" name="adm_geral" value="sim" checked> Sim
                            </label>
                            <label class="radio-label">
                                <input type="radio" name="adm_geral" value="não"> Não
                            </label>
                        </section>
                    </section>

                </fieldset>
            </form>
        </main>
    </section>

    <script src="/js/admin-add.js"></script>
</body>
</html> 