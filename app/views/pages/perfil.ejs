<%
    const isArtist = usuario && usuario.role === 'artista';
    const fotoPerfil = usuario && (usuario.fotoPerfil || usuario.foto_perfil);
    const nomeBanda = usuario && (usuario.nomeBanda || usuario.nome_banda || usuario.username);
    const estiloMusical = usuario && (usuario.estiloMusical || usuario.estilo_musical);
    const nomeCompleto = usuario && (usuario.nomeCompleto || usuario.nome_completo);
    const numIntegrantes = usuario && (usuario.numIntegrantes || usuario.num_integrantes);
    const statusConta = usuario && (usuario.statusConta || usuario.status_conta);
    const suspensoAte = usuario && (usuario.suspensoAte || usuario.suspenso_ate);
    const parseDataLocal = (valor) => {
        if (!valor) return null;
        if (valor instanceof Date) return valor;

        const texto = String(valor).slice(0, 10);
        const partes = texto.split('-').map(Number);

        if (partes.length === 3 && partes.every(Number.isFinite)) {
            return new Date(partes[0], partes[1] - 1, partes[2]);
        }

        const data = new Date(valor);
        return Number.isNaN(data.getTime()) ? null : data;
    };
    const dataSuspensao = parseDataLocal(suspensoAte);
    const hojeSuspensao = new Date();
    hojeSuspensao.setHours(0, 0, 0, 0);
    const diasSuspensaoRestantes = statusConta === 'suspenso' && dataSuspensao && dataSuspensao >= hojeSuspensao
        ? Math.max(1, Math.ceil((dataSuspensao - hojeSuspensao) / (1000 * 60 * 60 * 24)))
        : null;
    const integrantesLabel = {
        solo: 'Solo',
        '2a4': 'De 2 a 4 integrantes',
        mais4: 'Mais de 4 integrantes'
    }[numIntegrantes] || numIntegrantes || 'Nao informado';
%>
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= titulo %> - Cordas Soltas</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/perfil.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body>

    <%- include("../partials/header"); %>

    <main class="perfil-container">
        
        <section class="perfil-avatar-section">
            <h1 class="perfil-main-title">
                PERFIL <%= isArtist ? 'Artista' : 'Visitante' %>
            </h1>

            <% if (erro) { %>
                <p class="perfil-alerta perfil-alerta-erro"><%= erro %></p>
            <% } %>

            <% if (sucesso) { %>
                <p class="perfil-alerta perfil-alerta-sucesso"><%= sucesso %></p>
            <% } %>

            <% if (diasSuspensaoRestantes) { %>
                <p class="perfil-alerta perfil-alerta-suspensao">sua conta foi suspensa por: <%= diasSuspensaoRestantes %> dias</p>
            <% } %>

            <figure class="avatar-wrapper" id="avatar-trigger" tabindex="0" role="button" aria-label="Alterar foto de perfil">
                <% if (fotoPerfil) { %>
                    <img src="<%= fotoPerfil %>" alt="Foto de perfil de <%= isArtist ? nomeBanda : usuario.username %>" id="avatar-img">
                <% } else { %>
                    <span class="avatar-placeholder" aria-hidden="true"></span>
                <% } %>
            </figure>
            <p class="avatar-legenda">Toque para alterar a foto</p>
            
            <p class="tipo-conta-tag">
                <%= isArtist ? 'Conta Artista' : 'Conta Visitante' %>
            </p>

            <input type="file" id="upload-foto" style="display: none;" accept="image/*">
        </section>

        <section class="perfil-section">
            <h2 class="section-title">Informacoes da conta</h2>
            
            <ul class="perfil-card-lista">
                <li class="perfil-item">
                    <article class="item-dados">
                        <i class="fas fa-envelope item-icon" aria-hidden="true"></i>
                        <header>
                            <span class="item-label">Email</span>
                            <p class="item-valor"><%= usuario.email %></p>
                        </header>
                    </article>
                    <button type="button" class="btn-editar-campo" aria-label="Editar Email" data-editar-campo data-campo="email" data-valor="<%= usuario.email || '' %>">
                        <i class="fas fa-edit" aria-hidden="true"></i>
                    </button>
                </li>

                <li class="perfil-item">
                    <article class="item-dados">
                        <i class="fas fa-phone-alt item-icon" aria-hidden="true"></i>
                        <header>
                            <span class="item-label">Telefone</span>
                            <p class="item-valor"><%= usuario.telefone || 'Nao informado' %></p>
                        </header>
                    </article>
                    <button type="button" class="btn-editar-campo" aria-label="Editar Telefone" data-editar-campo data-campo="telefone" data-valor="<%= usuario.telefone || '' %>">
                        <i class="fas fa-edit" aria-hidden="true"></i>
                    </button>
                </li>

                <% if (isArtist) { %>
                    <li class="perfil-item">
                        <article class="item-dados">
                            <i class="fas fa-users item-icon" aria-hidden="true"></i>
                            <header>
                                <span class="item-label">Nome da banda</span>
                                <p class="item-valor"><%= nomeBanda || 'Nao informado' %></p>
                            </header>
                        </article>
                        <button type="button" class="btn-editar-campo" aria-label="Editar Nome da Banda" data-editar-campo data-campo="nome_banda" data-valor="<%= nomeBanda || '' %>">
                            <i class="fas fa-edit" aria-hidden="true"></i>
                        </button>
                    </li>

                    <li class="perfil-item">
                        <article class="item-dados">
                            <i class="fas fa-user-friends item-icon" aria-hidden="true"></i>
                            <header>
                                <span class="item-label">Numero de integrantes</span>
                                <p class="item-valor"><%= integrantesLabel %></p>
                            </header>
                        </article>
                        <button type="button" class="btn-editar-campo" aria-label="Editar Numero de Integrantes" data-editar-campo data-campo="num_integrantes" data-valor="<%= numIntegrantes || '' %>">
                            <i class="fas fa-edit" aria-hidden="true"></i>
                        </button>
                    </li>

                    <li class="perfil-item">
                        <article class="item-dados">
                            <i class="fas fa-guitar item-icon" aria-hidden="true"></i>
                            <header>
                                <span class="item-label">Estilo musical</span>
                                <p class="item-valor"><%= estiloMusical || 'Nao informado' %></p>
                            </header>
                        </article>
                        <button type="button" class="btn-editar-campo" aria-label="Editar Estilo Musical" data-editar-campo data-campo="estilo_musical" data-valor="<%= estiloMusical || '' %>">
                            <i class="fas fa-edit" aria-hidden="true"></i>
                        </button>
                    </li>

                    <li class="perfil-item">
                        <article class="item-dados">
                            <i class="fab fa-instagram item-icon" aria-hidden="true"></i>
                            <header>
                                <span class="item-label">Instagram</span>
                                <p class="item-valor"><%= usuario.instagram || 'Nao informado' %></p>
                            </header>
                        </article>
                        <button type="button" class="btn-editar-campo" aria-label="Editar Instagram" data-editar-campo data-campo="instagram" data-valor="<%= usuario.instagram || '' %>">
                            <i class="fas fa-edit" aria-hidden="true"></i>
                        </button>
                    </li>
                <% } else { %>
                    <li class="perfil-item">
                        <article class="item-dados">
                            <i class="fas fa-user item-icon" aria-hidden="true"></i>
                            <header>
                                <span class="item-label">Nome de usuario</span>
                                <p class="item-valor"><%= usuario.username %></p>
                            </header>
                        </article>
                        <button type="button" class="btn-editar-campo" aria-label="Editar Nome de Usuario" data-editar-campo data-campo="username" data-valor="<%= usuario.username || '' %>">
                            <i class="fas fa-edit" aria-hidden="true"></i>
                        </button>
                    </li>

                    <li class="perfil-item">
                        <article class="item-dados">
                            <i class="fas fa-id-card item-icon" aria-hidden="true"></i>
                            <header>
                                <span class="item-label">Nome completo</span>
                                <p class="item-valor"><%= nomeCompleto || 'Nao informado' %></p>
                            </header>
                        </article>
                        <button type="button" class="btn-editar-campo" aria-label="Editar Nome Completo" data-editar-campo data-campo="nome_completo" data-valor="<%= nomeCompleto || '' %>">
                            <i class="fas fa-edit" aria-hidden="true"></i>
                        </button>
                    </li>

                    <li class="perfil-item">
                        <article class="item-dados">
                            <i class="fas fa-fingerprint item-icon" aria-hidden="true"></i>
                            <header>
                                <span class="item-label">CPF</span>
                                <p class="item-valor"><%= usuario.cpf || 'Nao informado' %></p>
                            </header>
                        </article>
                        <button type="button" class="btn-editar-campo" aria-label="Editar CPF" data-editar-campo data-campo="cpf" data-valor="<%= usuario.cpf || '' %>">
                            <i class="fas fa-edit" aria-hidden="true"></i>
                        </button>
                    </li>
                <% } %>
            </ul>
        </section>

        <section class="perfil-section">
            <h2 class="section-title">Seguranca</h2>
            <ul class="perfil-card-lista">
                <li class="perfil-item">
                    <article class="item-dados">
                        <i class="fas fa-lock item-icon" aria-hidden="true"></i>
                        <header>
                            <span class="item-label">Senha</span>
                            <p class="item-valor">************</p>
                        </header>
                    </article>
                    <button type="button" class="btn-editar-campo" aria-label="Alterar Senha" id="btn-abrir-senha">
                        <i class="fas fa-edit" aria-hidden="true"></i>
                    </button>
                </li>
            </ul>
        </section>

        <section class="logout-section">
            <button type="button" class="btn-logout" onclick="abrirModalLogout()">
                <i class="fas fa-sign-out-alt"></i> Sair da Conta
            </button>
        </section>

    </main>

    <dialog id="modal-editar-campo" class="modal-caixa modal-edicao">
        <form method="POST" action="/perfil/editar" class="modal-conteudo-interno">
            <header class="modal-header">
                <i class="fas fa-pen modal-icon modal-icon-edicao" aria-hidden="true"></i>
                <h3 class="modal-titulo" id="modal-editar-titulo">Editar informacao</h3>
            </header>

            <input type="hidden" name="campo" id="modal-campo">

            <label class="modal-label" for="modal-valor-input" id="modal-editar-label">Valor</label>
            <input class="modal-input" type="text" name="valor" id="modal-valor-input">
            <select class="modal-input" name="valor" id="modal-valor-select" disabled hidden></select>

            <menu class="modal-botoes">
                <button type="button" class="btn-modal-cancelar" id="btn-fechar-edicao">Cancelar</button>
                <button type="submit" class="btn-modal-confirmar btn-modal-salvar">Salvar</button>
            </menu>
        </form>
    </dialog>

    <dialog id="modal-senha" class="modal-caixa modal-edicao">
        <form method="POST" action="/perfil/senha" class="modal-conteudo-interno">
            <header class="modal-header">
                <i class="fas fa-lock modal-icon modal-icon-edicao" aria-hidden="true"></i>
                <h3 class="modal-titulo">Alterar senha</h3>
            </header>

            <label class="modal-label" for="novaSenha">Nova senha</label>
            <input class="modal-input" type="password" name="novaSenha" id="novaSenha" minlength="6" required>

            <label class="modal-label" for="confirmarSenha">Confirmar senha</label>
            <input class="modal-input" type="password" name="confirmarSenha" id="confirmarSenha" minlength="6" required>

            <menu class="modal-botoes">
                <button type="button" class="btn-modal-cancelar" id="btn-fechar-senha">Cancelar</button>
                <button type="submit" class="btn-modal-confirmar btn-modal-salvar">Salvar</button>
            </menu>
        </form>
    </dialog>

    <dialog id="modal-logout" class="modal-caixa">
        <div class="modal-conteudo-interno">
            <header class="modal-header">
                <i class="fas fa-exclamation-triangle modal-icon" aria-hidden="true"></i>
                <h3 class="modal-titulo">Deseja mesmo sair?</h3>
            </header>
            
            <p class="modal-texto">Voce precisara fazer login novamente para acessar seus dados.</p>
            
            <menu class="modal-botoes">
                <button type="button" class="btn-modal-cancelar" onclick="fecharModalLogout()">Cancelar</button>
                <a href="/logout" class="btn-modal-confirmar">Sair da Conta</a>
            </menu>
        </div>
    </dialog>

    <%- include("../partials/menu"); %>

    <script src="/js/script.js"></script>
    <script>
        const camposPerfil = {
            email: { rotulo: 'Email', tipo: 'email', obrigatorio: true },
            telefone: { rotulo: 'Telefone', tipo: 'tel', obrigatorio: false },
            username: { rotulo: 'Nome de usuario', tipo: 'text', obrigatorio: true },
            nome_completo: { rotulo: 'Nome completo', tipo: 'text', obrigatorio: false },
            cpf: { rotulo: 'CPF', tipo: 'text', obrigatorio: false },
            nome_banda: { rotulo: 'Nome da banda', tipo: 'text', obrigatorio: true },
            instagram: { rotulo: 'Instagram', tipo: 'text', obrigatorio: false },
            num_integrantes: {
                rotulo: 'Numero de integrantes',
                obrigatorio: false,
                opcoes: [
                    { valor: '', texto: 'Nao informado' },
                    { valor: 'solo', texto: 'Solo' },
                    { valor: '2a4', texto: 'De 2 a 4 integrantes' },
                    { valor: 'mais4', texto: 'Mais de 4 integrantes' }
                ]
            },
            estilo_musical: {
                rotulo: 'Estilo musical',
                obrigatorio: true,
                opcoes: [
                    { valor: '', texto: 'Selecione um estilo' },
                    { valor: 'Rock', texto: 'Rock' },
                    { valor: 'Samba', texto: 'Samba' },
                    { valor: 'Pagode', texto: 'Pagode' },
                    { valor: 'Jazz', texto: 'Jazz' },
                    { valor: 'Eletrônica', texto: 'Eletrônica' },
                    { valor: 'Forró', texto: 'Forró' },
                    { valor: 'Sertanejo', texto: 'Sertanejo' },
                    { valor: 'MPB', texto: 'MPB' },
                    { valor: 'Reggae', texto: 'Reggae' },
                    { valor: 'Hip-Hop/Rap', texto: 'Hip-Hop / Rap' },
                    { valor: 'Metal', texto: 'Metal' },
                    { valor: 'Pop', texto: 'Pop' },
                    { valor: 'Outro', texto: 'Outro' }
                ]
            }
        };

        const modalEdicao = document.getElementById('modal-editar-campo');
        const modalSenha = document.getElementById('modal-senha');
        const modalLogout = document.getElementById('modal-logout');
        const inputCampo = document.getElementById('modal-campo');
        const inputValor = document.getElementById('modal-valor-input');
        const selectValor = document.getElementById('modal-valor-select');
        const labelEdicao = document.getElementById('modal-editar-label');
        const tituloEdicao = document.getElementById('modal-editar-titulo');

        function abrirDialog(dialog) {
            if (typeof dialog.showModal === 'function') {
                dialog.showModal();
            } else {
                dialog.setAttribute('open', 'true');
            }
        }

        function fecharDialog(dialog) {
            if (typeof dialog.close === 'function') {
                dialog.close();
            } else {
                dialog.removeAttribute('open');
            }
        }

        document.querySelectorAll('[data-editar-campo]').forEach((botao) => {
            botao.addEventListener('click', () => {
                const campo = botao.dataset.campo;
                const valorAtual = botao.dataset.valor || '';
                const config = camposPerfil[campo];

                if (!config) return;

                inputCampo.value = campo;
                tituloEdicao.textContent = `Editar ${config.rotulo}`;
                labelEdicao.textContent = config.rotulo;

                if (config.opcoes) {
                    inputValor.disabled = true;
                    inputValor.hidden = true;
                    inputValor.required = false;
                    selectValor.disabled = false;
                    selectValor.hidden = false;
                    selectValor.required = Boolean(config.obrigatorio);
                    selectValor.innerHTML = config.opcoes
                        .map(opcao => `<option value="${opcao.valor}">${opcao.texto}</option>`)
                        .join('');
                    selectValor.value = valorAtual;
                } else {
                    selectValor.disabled = true;
                    selectValor.hidden = true;
                    selectValor.required = false;
                    inputValor.disabled = false;
                    inputValor.hidden = false;
                    inputValor.type = config.tipo || 'text';
                    inputValor.required = Boolean(config.obrigatorio);
                    inputValor.value = valorAtual;
                    inputValor.focus();
                }

                abrirDialog(modalEdicao);
            });
        });

        document.getElementById('btn-fechar-edicao').addEventListener('click', () => fecharDialog(modalEdicao));
        document.getElementById('btn-abrir-senha').addEventListener('click', () => abrirDialog(modalSenha));
        document.getElementById('btn-fechar-senha').addEventListener('click', () => fecharDialog(modalSenha));

        function abrirModalLogout() {
            abrirDialog(modalLogout);
        }

        function fecharModalLogout() {
            fecharDialog(modalLogout);
        }

        [modalEdicao, modalSenha, modalLogout].forEach((modal) => {
            modal.addEventListener('click', (event) => {
                if (event.target === modal) {
                    fecharDialog(modal);
                }
            });
        });

        const avatarTrigger = document.getElementById('avatar-trigger');
        const uploadFoto = document.getElementById('upload-foto');

        avatarTrigger.addEventListener('click', () => uploadFoto.click());
        avatarTrigger.addEventListener('keydown', (event) => {
            if (event.key === 'Enter' || event.key === ' ') {
                event.preventDefault();
                uploadFoto.click();
            }
        });

        uploadFoto.addEventListener('change', () => {
            const arquivo = uploadFoto.files && uploadFoto.files[0];
            if (!arquivo) return;

            const leitor = new FileReader();
            leitor.onload = async (event) => {
                const resposta = await fetch('/perfil/foto', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ fotoBase64: event.target.result })
                });
                const resultado = await resposta.json();

                if (resultado.ok) {
                    window.location.href = '/perfil?sucesso=' + encodeURIComponent('Foto atualizada com sucesso');
                } else {
                    alert(resultado.mensagem || 'Nao foi possivel atualizar a foto.');
                }
            };
            leitor.readAsDataURL(arquivo);
        });
    </script>
</body>
</html>
